#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILD_DIR="${QTcode_BUILD_DIR:-$ROOT_DIR/build}"

if [[ ! -d "$BUILD_DIR" ]]; then
  echo "ERROR: build directory not found at $BUILD_DIR" >&2
  echo "Run scripts/build-app first." >&2
  exit 1
fi

if [[ ! -f "$BUILD_DIR/CMakeCache.txt" ]]; then
  echo "ERROR: $BUILD_DIR does not look like a configured CMake build directory" >&2
  echo "Run scripts/build-app first." >&2
  exit 1
fi

ctest --test-dir "$BUILD_DIR" --output-on-failure "$@"

#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_PYTHON="$ROOT_DIR/.venv/bin/python"

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "ERROR: missing virtualenv Python at $VENV_PYTHON" >&2
  echo "Create it with: python3 -m venv .venv" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  echo "Usage: scripts/search-memory [--limit N] query..." >&2
  exit 1
fi

exec "$VENV_PYTHON" "$ROOT_DIR/tools/search_memory.py" "$@"

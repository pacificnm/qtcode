#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_PYTHON="$ROOT_DIR/.venv/bin/python"

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "ERROR: missing virtualenv Python at $VENV_PYTHON" >&2
  echo "Create it with: python3 -m venv .venv" >&2
  exit 1
fi

if [[ $# -lt 2 ]]; then
  echo "Usage: scripts/save-agent-context --scope-key SCOPE [--session-id ID] [--context-type TYPE] [--title TITLE] content..." >&2
  exit 1
fi

exec "$VENV_PYTHON" "$ROOT_DIR/tools/save_agent_context.py" "$@"

#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILD_DIR="${QTcode_BUILD_DIR:-$ROOT_DIR/build}"
SOURCE_DIR="$ROOT_DIR"

if [[ ! -f "$SOURCE_DIR/CMakeLists.txt" ]]; then
  echo "ERROR: no CMakeLists.txt found at $SOURCE_DIR" >&2
  echo "The build script is ready, but the app build system has not been added yet." >&2
  exit 1
fi

if command -v ninja >/dev/null 2>&1; then
  GENERATOR="${CMAKE_GENERATOR:-Ninja}"
else
  GENERATOR="${CMAKE_GENERATOR:-Unix Makefiles}"
fi

cmake -S "$SOURCE_DIR" -B "$BUILD_DIR" -G "$GENERATOR" -DCMAKE_BUILD_TYPE="${CMAKE_BUILD_TYPE:-Debug}" "$@"
cmake --build "$BUILD_DIR" --parallel "${CMAKE_BUILD_PARALLEL_LEVEL:-$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 4)}"
